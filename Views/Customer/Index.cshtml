@model IEnumerable<Customer>

<h2>Customers</h2>

<p>
    <a href="~/Customer/Register" class="btn btn-primary">Register New Customer</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Company</th>
            <th>Address</th>
            <th>City</th>
            <th>Region</th>
            <th>Postal Code</th>
            <th>Country</th>
            <th>Phone</th>
            <th>Fax</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Customer customer in Model)
        {
            <tr>
                <td>@customer.CompanyName</td>
                <td>@customer.Address</td>
                <td>@customer.City</td>
                <td>@customer.Region</td>
                <td>@customer.PostalCode</td>
                <td>@customer.Country</td>
                <td>@customer.Phone</td>
                <td>@customer.Fax</td>
            </tr>
        }
    </tbody>
</table>
