@model IEnumerable<Product>

<h2>Products in @ViewBag.CategoryName</h2>

<ul class="list-group">
    @foreach (Product product in Model)
    {
        <li class="list-group-item">@product.ProductName</li>
    }
</ul>

<p class="mt-3">
    <a href="@Url.Action("Category", "Product")">Back to categories</a>
</p>